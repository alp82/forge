{
  "hooks": {
    "BeforeAgent": [
      {
        "type": "command",
        "command": "adapters/gemini/hooks/session-start.sh",
        "timeout": 5000,
        "statusMessage": "forge: injecting session context"
      }
    ],
    "BeforeTool": [
      {
        "matcher": "^(run_shell_command|shell|local_shell|bash|Bash|exec_command)$",
        "type": "command",
        "command": "adapters/gemini/hooks/block-git-writes.sh",
        "timeout": 5000,
        "statusMessage": "forge: git-write guard"
      }
    ],
    "AfterTool": [
      {
        "matcher": "^(write_file|replace|apply_patch|edit|write|str_replace|create_file|Edit|Write)$",
        "type": "command",
        "command": "python3 adapters/gemini/hooks/mark-code-change.py",
        "timeout": 5000,
        "statusMessage": "forge: change tracking"
      }
    ],
    "AfterAgent": [
      {
        "type": "command",
        "command": "python3 adapters/gemini/hooks/verify-tests.py",
        "timeout": 130000,
        "statusMessage": "forge: verifying tests"
      },
      {
        "type": "command",
        "command": "python3 adapters/gemini/hooks/verify-build.py",
        "timeout": 190000,
        "statusMessage": "forge: verifying build"
      },
      {
        "type": "command",
        "command": "python3 adapters/gemini/hooks/review-owed.py",
        "timeout": 5000,
        "statusMessage": "forge: review-owed gate"
      }
    ]
  }
}
