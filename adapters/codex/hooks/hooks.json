{
  "hooks": {
    "SessionStart": [
      {
        "command": "adapters/codex/hooks/session-start.sh",
        "timeout": 5,
        "statusMessage": "forge: injecting session context"
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^(shell|local_shell|bash|Bash|exec_command)$",
        "command": "adapters/codex/hooks/block-git-writes.sh",
        "timeout": 5,
        "statusMessage": "forge: git-write guard"
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(apply_patch|edit|write|str_replace|create_file|Edit|Write)$",
        "command": "python3 adapters/codex/hooks/mark-code-change.py",
        "timeout": 5,
        "statusMessage": "forge: change tracking"
      }
    ],
    "Stop": [
      {
        "command": "python3 adapters/codex/hooks/verify-tests.py",
        "timeout": 130,
        "statusMessage": "forge: verifying tests"
      },
      {
        "command": "python3 adapters/codex/hooks/verify-build.py",
        "timeout": 190,
        "statusMessage": "forge: verifying build"
      },
      {
        "command": "python3 adapters/codex/hooks/review-owed.py",
        "timeout": 5,
        "statusMessage": "forge: review-owed gate"
      }
    ]
  }
}
